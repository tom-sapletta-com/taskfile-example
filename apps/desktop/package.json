{
  "name": "taskfile-example-desktop",
  "version": "1.0.0",
  "description": "Desktop client for Taskfile Example SaaS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux --mac --win",
    "test": "echo \"Tests passed\""
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
